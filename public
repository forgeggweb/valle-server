  let open = false;
  let rafId = null;
  let bmImg = null; // cached background image
  let bmDirty = true;

  // Tile colors for the big map
  const TILE_COLORS = {
    0: '#5aaf32',   // GRASS
    1: '#2460c0',   // WATER
    2: '#267a1c',   // TREE
    3: '#6a6a6a',   // ROCK
    4: '#d4a840',   // WHEAT
    5: '#a87038',   // DIRT
    6: '#e0cc78',   // SAND
    7: '#c09050',   // PATH
    8: '#e02040',   // FLOWER
    9: '#d84030',   // MUSHROOM
    10: '#4a9a28',  // TALL_GRASS
    11: '#a07040',  // BRIDGE
    12: '#e060a0',  // LILY
    13: '#3a8828',  // BUSH
    14: '#886020',  // TILLED
    15: '#f0d880',  // CROP
    16: '#8a6030',  // SHOP
    17: '#5a3018',  // BED
    18: '#3a2810',  // CHEST
    19: '#4a4a4a',  // MINE
    20: '#c89030',  // FENCE
    21: '#7a6040',  // SIGN
    22: '#a86028',  // SCARECROW
