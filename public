      ctx.font = `bold ${Math.max(8, ps * 4)}px "Press Start 2P", monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillStyle = 'rgba(255,255,255,0.18)';
      ctx.fillText('NORTE', w/2, ps * 20);
      ctx.fillText('SUR', w/2, h - ps * 20);
      ctx.fillText('OESTE', ps * 30, h/2);
      ctx.fillText('ESTE', w - ps * 30, h/2);
      ctx.restore();
    }

    // Draw remote players
    const remotePlayers = window._mp ? window._mp.remotePlayers : null;
    const TILE = 48;
    const playerDots = [];

    if (remotePlayers) {
      for (const id in remotePlayers) {
        const rp = remotePlayers[id];
        const px = ((rp.x + 24) / TILE) * ps;
        const py = ((rp.y + 24) / TILE) * ps;
        const dotR = Math.max(4, ps * 1.5);
        // Outer glow
        ctx.save();
        ctx.shadowColor = rp.color || '#ff8080';
        ctx.shadowBlur = dotR * 2;
        ctx.beginPath();
        ctx.arc(px, py, dotR, 0, Math.PI * 2);
        ctx.fillStyle = rp.color || '#ff8080';
        ctx.fill();
        ctx.shadowBlur = 0;
        // White border
        ctx.strokeStyle = 'white';
        ctx.lineWidth = Math.max(1, ps * 0.4);
        ctx.stroke();
        ctx.restore();
        // Name label
        const name = rp.name || 'Jugador';
        ctx.save();
        const fs = Math.max(6, Math.min(11, ps * 3));
        ctx.font = `bold ${fs}px "Press Start 2P", monospace`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'bottom';
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 2.5;
        ctx.strokeText(name, px, py - dotR - 2);
        ctx.fillStyle = rp.color || '#ff8080';
        ctx.fillText(name, px, py - dotR - 2);
        ctx.restore();
        playerDots.push({ name, color: rp.color || '#ff8080' });
      }
    }

    // Draw local player
    if (typeof player !== 'undefined') {
      const px = ((player.x + 24) / TILE) * ps;
      const py = ((player.y + 24) / TILE) * ps;
      const dotR = Math.max(5, ps * 1.8);
      // Pulsing ring
      const pulse = 0.5 + 0.5 * Math.sin(Date.now() * 0.005);
      ctx.save();
      ctx.strokeStyle = `rgba(255,255,100,${0.4 + 0.4 * pulse})`;
      ctx.lineWidth = Math.max(1.5, ps * 0.5);
      ctx.beginPath();
      ctx.arc(px, py, dotR * (1.5 + 0.3 * pulse), 0, Math.PI * 2);
      ctx.stroke();
      // Fill
      ctx.shadowColor = '#f8e040';
      ctx.shadowBlur = dotR * 2.5;
      ctx.beginPath();
      ctx.arc(px, py, dotR, 0, Math.PI * 2);
      ctx.fillStyle = '#f8e040';
      ctx.fill();
      ctx.shadowBlur = 0;
      ctx.strokeStyle = '#fff';
      ctx.lineWidth = Math.max(1, ps * 0.5);
      ctx.stroke();
      ctx.restore();
      // "TÚ" label
      const myName = window.MY_NAME || 'Tú';
      const fs = Math.max(6, Math.min(11, ps * 3));
      ctx.save();
      ctx.font = `bold ${fs}px "Press Start 2P", monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'bottom';
      ctx.strokeStyle = '#000';
      ctx.lineWidth = 2.5;
      ctx.strokeText('★ ' + myName, px, py - dotR - 2);
      ctx.fillStyle = '#f8e040';
      ctx.fillText('★ ' + myName, px, py - dotR - 2);
      ctx.restore();
      playerDots.unshift({ name: '★ ' + myName, color: '#f8e040', isLocal: true });
    }

    // Update legend
    legendEl.innerHTML = '';
    for (const pd of playerDots) {
      const dot = `<span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${pd.color};border:1.5px solid #fff;vertical-align:middle;margin-right:4px;"></span>`;
      legendEl.innerHTML += `<span style="white-space:nowrap;">${dot}${pd.name}</span>`;
    }

    // Coords display: update on mousemove
    rafId = requestAnimationFrame(drawMap);
  }

  canvas.addEventListener('mousemove', function(e) {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const { ps } = calcSize();
    const col = Math.floor(mx / ps);
    const row = Math.floor(my / ps);
    coordsEl.textContent = `Tile: ${col}, ${row}  |  Pixel: ${col*48}, ${row*48}`;
  });

  function openMap() {
    if (open) return;
    open = true;
    bmDirty = true;
    overlay.style.display = 'flex';
    drawMap();
  }

  function closeMap() {
    if (!open) return;
    open = false;
    overlay.style.display = 'none';
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
  }

  // Toggle on M key
  document.addEventListener('keydown', function(e) {
    const tag = document.activeElement && document.activeElement.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA') return;
    if (e.code === 'KeyM') {
      e.preventDefault();
      e.stopImmediatePropagation();
      open ? closeMap() : openMap();
    }
    if (e.code === 'Escape' && open) {
      closeMap();
    }
  }, true);

  // Close on overlay click (outside the map canvas/controls)
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeMap();
  });

  // Mark dirty whenever tiles change (hook mmBuilt)
  const _origDescriptor = Object.getOwnPropertyDescriptor(window, 'mmBuilt');
  try {
    let _mmVal = (typeof mmBuilt !== 'undefined') ? mmBuilt : true;
    Object.defineProperty(window, 'mmBuilt', {
      get: () => _mmVal,
      set: (v) => { _mmVal = v; if (!v) bmDirty = true; },
      configurable: true
    });
  } catch(e) {}

  window._bigMap = { open: openMap, close: closeMap };
})();
</script>
