  function calcSize() {
    // Fit map to viewport: max 92vw x 80vh
    const maxW = Math.floor(window.innerWidth * 0.92);
    const maxH = Math.floor(window.innerHeight * 0.78);
    const COLS = 480, ROWS = 336;
    const scaleW = maxW / COLS;
    const scaleH = maxH / ROWS;
    const scale = Math.min(scaleW, scaleH);
    // Use integer-ish scale for crisp pixels
    const ps = Math.max(1, Math.floor(scale)); // pixels per tile, at least 1
    return { ps, w: COLS * ps, h: ROWS * ps, COLS, ROWS };
  }

  function buildBackground(ps, w, h, COLS, ROWS) {
    const offscreen = document.createElement('canvas');
    offscreen.width = w;
    offscreen.height = h;
    const oc = offscreen.getContext('2d');
    if (typeof tileTypes === 'undefined') return offscreen;
    for (let row = 0; row < ROWS; row++) {
      for (let col = 0; col < COLS; col++) {
        const t = tileTypes[row][col];
        oc.fillStyle = TILE_COLORS[t] || '#5aaf32';
        oc.fillRect(col * ps, row * ps, ps, ps);
      }
